# .env.example — Copy this to .env and fill in your real values

# --- Mode ---
MOCK_MODE=true

# --- Google Cloud & Gemini ---
GCP_PROJECT_ID="your_google_cloud_project_id_here"
GEMINI_API_KEY="paste_your_gemini_api_key_here" 

# --- Dynatrace ---
DT_ENDPOINT="https://YOUR_TENANT.live.dynatrace.com"
DT_API_TOKEN="your_dynatrace_api_token_here"
DT_ENVIRONMENT="https://YOUR_TENANT.apps.dynatrace.com"
DT_PLATFORM_TOKEN="your_dynatrace_platform_token_here"

# --- Application Settings ---
ENVIRONMENT="development"
BUDGET_USD_PER_HOUR="50"
